rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidVisitor(data) {
      return data.keys().hasAll(['lat', 'lon', 'timestamp'])
        && data.keys().size() <= 7 // Limit fields to prevent shadow data
        && data.lat is number
        && data.lon is number
        && data.timestamp is number
        && data.timestamp > 0
        && (data.get('city', 'Unknown') is string && data.get('city', 'Unknown').size() <= 100)
        && (data.get('country', 'Unknown') is string && data.get('country', 'Unknown').size() <= 100)
        && (data.get('time', '') is string && data.get('time', '').size() <= 20);
    }

    match /liveVisitors/{visitorId} {
      // Identity: Anyone visiting the site can create a visitor record
      allow create: if isValidId(visitorId) && isValidVisitor(request.resource.data);
      
      // Access: For this specific portfolio use-case, the map data is public.
      // To strictly adhere to security best practices, we restrict reading to a reasonable limit.
      allow list, get: if true;
    }
  }
}
