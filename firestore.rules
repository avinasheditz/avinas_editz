rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidVisitor(data) {
      return data.keys().hasAll(['lat', 'lon', 'timestamp'])
        && data.keys().size() <= 8
        && data.lat is number
        && data.lon is number
        && data.timestamp is number
        && data.timestamp > 0;
    }

    function isValidProjectRequest(data) {
      return data.keys().hasAll(['clientName', 'email', 'projectName', 'createdAt'])
        && data.keys().size() <= 10
        && data.clientName is string && data.clientName.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.projectName is string && data.projectName.size() <= 200
        && data.createdAt == request.time;
    }

    match /liveVisitors/{visitorId} {
      allow create: if isValidId(visitorId) && isValidVisitor(request.resource.data);
      allow list, get: if true;
    }

    match /projectRequests/{requestId} {
      allow create: if isValidProjectRequest(request.resource.data);
      allow list, get: if true;
    }
  }
}
